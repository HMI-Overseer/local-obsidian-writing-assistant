{
  "name": "writing-assistant-chat",
  "version": "1.0.0",
  "description": "Obsidian plugin: Writing Assistant Chat",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "build:css": "postcss src/styles/index.css -o styles.css",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:all": "vitest run",
    "test:unit": "vitest run --include 'tests/unit/**/*.test.ts'",
    "test:integration": "vitest run --include 'tests/integration/**/*.test.ts'",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [],
  "author": "Harbingers",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/utils": "^8.58.0",
    "@vitest/coverage-v8": "^4.1.2",
    "autoprefixer": "10.4.20",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.21.0",
    "eslint": "^9.39.0",
    "eslint-plugin-obsidianmd": "^0.1.9",
    "obsidian": "latest",
    "postcss": "8.4.49",
    "postcss-cli": "11.0.0",
    "postcss-import": "16.1.0",
    "tailwindcss": "3.4.17",
    "tslib": "2.6.0",
    "typescript": "5.3.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  }
}
